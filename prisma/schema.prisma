generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum EstadoEvento {
  borrador
  publicada
  archivada
}

enum EstadoSolicitud {
  pendiente
  aprobada
  rechazada
}

enum TipoPunto {
  salida
  parada
  destino
}

enum TipoCampo {
  texto
  numero
  email
  telefono
  select
  checkbox
}

type PuntoRuta {
  tipo        TipoPunto
  nombre      String
  descripcion String?
  lat         Float
  lng         Float
  orden       Int
  fotos       String[]
}

type CampoFormulario {
  etiqueta  String
  clave     String
  tipo      TipoCampo
  opciones  String[]
  requerido Boolean
  ayuda     String?
  orden     Int
  activo    Boolean
}

type RequisitoMinimo {
  texto String
  orden Int
}

model Evento {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  nombre      String
  descripcion String
  fecha       DateTime
  horaSalida  String
  cuposMax    Int
  estado      EstadoEvento      @default(borrador)
  dificultad  String?
  distanciaKm Float?
  puntos      PuntoRuta[]
  campos      CampoFormulario[]
  requisitos  RequisitoMinimo[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  solicitudes Solicitud[]
}

model Solicitud {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  evento        Evento          @relation(fields: [eventoId], references: [id])
  eventoId      String          @db.ObjectId
  estado        EstadoSolicitud @default(pendiente)
  motivoRechazo String?
  respuestas    Json
  correo        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([eventoId, correo])
}
