# --- Base de datos ---
# Connection string de MongoDB (Atlas). Crea un cluster gratuito (M0) en https://www.mongodb.com/atlas
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<nombreDB>?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/rodada?retryWrites=true&w=majority"

# --- Admin ---
# Contraseña única para entrar al panel /admin
ADMIN_PASSWORD="cambia-esta-clave"

# Secreto para firmar la cookie de sesión del admin. Usa una cadena larga y aleatoria,
# por ejemplo generada con: openssl rand -base64 32
SESSION_SECRET="cambia-este-secreto-por-uno-aleatorio-y-largo"

# --- Mapa / Ruta ---
# Servidor OSRM público usado para calcular la ruta por calles. No requiere API key.
# Si tenés tu propio servidor OSRM, reemplazá esta URL.
NEXT_PUBLIC_OSRM_URL="https://router.project-osrm.org"

# --- Notificaciones por correo (opcional) ---
# Si EMAIL_ENABLED="true", al aprobar/rechazar una solicitud se envía un correo al solicitante.
EMAIL_ENABLED="false"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Rodada en Moto <no-reply@example.com>"
